      "id": "bgtu24gfs",
      "name": "CRM Sandbox",
      "description": "Dynamic sandbox CRM build",
      "config": {
        "name": "CRM Sandbox",
        "description": "Dynamic sandbox CRM build",
        "auth": {
          "enabled": true
        },
        "database": {
          "models": [
            {
              "name": "Lead",
              "fields": [
                {
                  "name": "fullName",
                  "type": "String",
                  "required": true
                },
                {
                  "name": "email",
                  "type": "String",
                  "required": false,
                  "unique": true
                },
                {
                  "name": "score",
                  "type": "Int",
                  "required": false
                }
              ]
            }
          ]
        },
        "ui": {
          "layout": "Sidebar",
          "pages": [
            {
              "id": "leads",
              "title": "Leads Manager",
              "components": [
                {
                  "id": "leads-table",
                  "type": "DataTable",
                  "props": {
                    "model": "Lead",
                    "columns": [
                      "fullName",
                      "email",
                      "score"
                    ],
                    "actions": [
                      "create",
                      "edit",
                      "delete"
                    ]
                  }
                }
              ]
            }
          ]
        },
        "apis": [],
        "workflows": [
          {
            "id": "wf-webhook-1",
            "name": "Trigger Webhook on Lead",
            "trigger": {
              "event": "RECORD_CREATED",
              "model": "Lead"
            },
            "actions": [
              {
                "type": "SEND_WEBHOOK",
                "config": {
                  "url": "https://webhook.site/dummy-placeholder-url-for-verification",
                  "payload": {
                    "id": "{{id}}",
                    "name": "{{fullName}}",
                    "status": "new"
                  }
                }
              },
              {
                "type": "LOG_EVENT",
                "config": {
                  "message": "Processed lead record with ID: {{id}}"
                }
              }
            ]
          }
        ]
      },
