      "id": "al3wqfj8k",
      "name": "FleetOps Logistics",
      "description": "Generate exactly two pages: a Dashboard and a Data Table. Model Name: \"DeliveryDispatch\". Fields required: \"TrackingNumber\" (String), \"DriverName\" (String), \"FuelExpense\" (Float), \"PackageCount\" (Int), \"DispatchDate\" (Date). The Dashboard must dynamically showcase two summary metrics: \"Total Dispatch Invoices\" and \"Aggregated Fuel Spend\". The Data Table must support live CSV ingestion for bulk route scheduling.",
      "config": {
        "name": "FleetOps Logistics",
        "description": "Generate exactly two pages: a Dashboard and a Data Table. Model Name: \"DeliveryDispatch\". Fields required: \"TrackingNumber\" (String), \"DriverName\" (String), \"FuelExpense\" (Float), \"PackageCount\" (Int), \"DispatchDate\" (Date). The Dashboard must dynamically showcase two summary metrics: \"Total Dispatch Invoices\" and \"Aggregated Fuel Spend\". The Data Table must support live CSV ingestion for bulk route scheduling.",
        "auth": {
          "enabled": true,
          "userModel": "User",
          "roles": [
            "Admin",
            "Member"
          ]
        },
        "database": {
          "models": [
            {
              "name": "FleetOp",
              "fields": [
                {
                  "name": "driverName",
                  "type": "String",
                  "required": true,
                  "unique": false
                },
                {
                  "name": "fuelExpense",
                  "type": "Float",
                  "required": false,
                  "unique": false
                },
                {
                  "name": "packageCount",
                  "type": "Int",
                  "required": false,
                  "unique": false
                },
                {
                  "name": "dispatchDate",
                  "type": "String",
                  "required": false,
                  "unique": false
                }
              ]
            }
          ]
        },
        "ui": {
          "layout": "Sidebar",
          "pages": [
            {
              "id": "fleetop-form-page",
              "title": "FleetOp Form",
              "route": "/fleetop-form",
              "components": [
                {
                  "id": "fleetop-form",
                  "type": "Form",
                  "props": {
                    "model": "FleetOp",
                    "fields": [
                      {
                        "name": "driverName",
                        "label": "Driver Name",
                        "type": "text"
                      },
                      {
                        "name": "fuelExpense",
                        "label": "Fuel Expense",
                        "type": "number"
                      },
                      {
                        "name": "packageCount",
                        "label": "Package Count",
                        "type": "number"
                      },
                      {
                        "name": "dispatchDate",
                        "label": "Dispatch Date",
                        "type": "text"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "id": "fleetops-list-page",
              "title": "FleetOp List",
              "route": "/fleetops-list",
              "components": [
                {
                  "id": "fleetops-stats",
                  "type": "StatsGrid",
                  "props": {
                    "items": [
                      {
                        "label": "Total FleetOps",
                        "value": "0",
                        "change": "Live records"
                      },
                      {
                        "label": "Total Package Count",
                        "value": "0",
                        "change": "Live count"
                      }
                    ]
                  }
                },
                {
                  "id": "fleetops-table",
                  "type": "DataTable",
                  "props": {
                    "model": "FleetOp",
                    "columns": [
                      "driverName",
                      "fuelExpense",
                      "packageCount",
                      "dispatchDate"
                    ],
                    "actions": [
                      "create",
                      "edit",
                      "delete",
                      "csv-import"
                    ]
                  }
                }
              ]
            }
          ]
        },
